# WarcraftLogs API credentials
# Create them at: https://www.warcraftlogs.com/api/clients/
VITE_WCL_CLIENT_ID=your_client_id_here
VITE_WCL_CLIENT_SECRET=your_client_secret_here

# Your character info
VITE_CHARACTER_NAME=YourCharName
VITE_SERVER_SLUG=area-52          # e.g. "area-52", "stormrage", "tarren-mill"
VITE_SERVER_REGION=US             # US, EU, KR, TW

# Optional: leave blank to auto-detect the latest raid zone
VITE_ZONE_ID=

# Optional overrides
VITE_METRIC=dps          # dps | hps | bossdps | tankhps
VITE_DIFFICULTY=5        # 3=Normal 4=Heroic 5=Mythic
VITE_REFRESH_INTERVAL=300000   # ms between auto-refresh (default 5 min)

# Layout variant
# compact  →  slim sidebar widget, ~400 px wide (default, good for sidebars/overlays)
# panel    →  full-viewport scene panel, fills whatever size you set in OBS browser source
#             (e.g. set the source to 800x600, 400x600 or any size — it adapts)
VITE_LAYOUT=compact

# Auto-rotation (panel mode only)
# Set VITE_GUILD_NAME and the widget auto-rotates between a guild progress panel
# and your parse panel — no iframe, no OBS scene switching needed.
# Leave VITE_GUILD_SERVER_SLUG / VITE_GUILD_SERVER_REGION blank to default
# to the character's server and region.
VITE_GUILD_NAME=
VITE_GUILD_SERVER_SLUG=     # optional, defaults to VITE_SERVER_SLUG
VITE_GUILD_SERVER_REGION=   # optional, defaults to VITE_SERVER_REGION
VITE_ROTATE_INTERVAL=30000  # ms each view is shown before fading (default 30s)
